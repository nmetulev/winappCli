<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="winui_app.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WinUI Sample"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="WinUI Sample">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <ScrollViewer Grid.Row="1" AutomationProperties.AutomationId="MainScroller">
            <StackPanel Padding="40" Spacing="16">

                <TextBlock
                    AutomationProperties.AutomationId="PageTitle"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="WinUI Sample App" />

                <TextBlock
                    AutomationProperties.AutomationId="PageSubtitle"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Used by winapp ui end-to-end tests" />

                <!-- Counter -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="CounterButton"
                        AutomationProperties.AutomationId="CounterButton"
                        AutomationProperties.Name="Counter Button"
                        Click="CounterButton_Click"
                        Content="Click Me" />
                    <TextBlock
                        x:Name="CounterText"
                        AutomationProperties.AutomationId="CounterDisplay"
                        VerticalAlignment="Center"
                        Text="Count: 0" />
                </StackPanel>

                <!-- Text input -->
                <TextBox
                    x:Name="InputTextBox"
                    AutomationProperties.AutomationId="TextInput"
                    AutomationProperties.Name="Text Input"
                    Header="Enter text:"
                    PlaceholderText="Type something here..." />

                <!-- CheckBox -->
                <CheckBox
                    x:Name="FeatureCheckBox"
                    AutomationProperties.AutomationId="FeatureToggle"
                    AutomationProperties.Name="Feature Toggle"
                    Content="Enable feature" />

                <!-- Submit + result -->
                <Button
                    x:Name="SubmitButton"
                    AutomationProperties.AutomationId="SubmitButton"
                    AutomationProperties.Name="Submit Button"
                    Click="SubmitButton_Click"
                    Content="Submit"
                    Style="{StaticResource AccentButtonStyle}" />

                <TextBlock
                    x:Name="ResultText"
                    AutomationProperties.AutomationId="ResultDisplay"
                    Text="" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
